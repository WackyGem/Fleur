# RustFS
RUSTFS_ACCESS_KEY=mono-fleur
RUSTFS_SECRET_KEY=change-me-rustfs-secret
RUSTFS_ENDPOINT=http://127.0.0.1:34050
RUSTFS_BUCKET=mono-fleur
RUSTFS_API_PORT=34050
RUSTFS_CONSOLE_PORT=34051
CLICKHOUSE_S3_ENDPOINT=http://rustfs:9000

# BaoStock
BAOSTOCK_HOST=public-api.baostock.com
BAOSTOCK_PORT=10030
BAOSTOCK_USERNAME=anonymous
BAOSTOCK_PASSWORD=123456

# ClickHouse
CLICKHOUSE_DB=mono_fleur
CLICKHOUSE_USER=mono_fleur
CLICKHOUSE_PASSWORD=change-me-clickhouse-password
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_HTTP_PORT=34052
CLICKHOUSE_NATIVE_PORT=34053
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=34052
CLICKHOUSE_DATABASE=raw
CLICKHOUSE_DBT_SCHEMA=analytics
CLICKHOUSE_SECURE=false
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=10
CLICKHOUSE_QUERY_TIMEOUT_SECONDS=300

# PostgreSQL
POSTGRES_DB=mono_fleur
POSTGRES_USER=mono_fleur
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=34054
PIPELINE_DATABASE_URL=postgresql://mono_fleur:change-me-postgres-password@127.0.0.1:34054/mono_fleur

# NATS
NATS_CLIENT_PORT=34055
NATS_MONITOR_PORT=34056

# JIUYAN
JIUYAN_TOKEN=change-me
JIUYAN_COOKIE=SESSION=change-me

# JIUYAN OCR
JIUYAN_OCR_BASE_URL=http://127.0.0.1:34005
JIUYAN_OCR_MODEL_NAME=Qwen3.5-4B
JIUYAN_OCR_TIMEOUT_SECONDS=180
JIUYAN_OCR_MAX_RETRIES=2
JIUYAN_OCR_MAX_CONCURRENT_REQUESTS=6
JIUYAN_OCR_STALE_RUNNING_SECONDS=3600

# Dagster
DAGSTER_HOME=/storage/program/mono-fleur/.dagster
DAGSTER_WEBSERVER_BASE_URL=http://localhost:3000
DAGSTER_CODE_LOCATION_NAME=scheduler

# SLACK
SLACK_BOT_TOKEN=xoxb-change-me
SLACK_CHANNEL_ID=C0000000000
SLACK_HTTP_PROXY=
