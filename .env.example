RUSTFS_BUCKET=mono-fleur
RUSTFS_API_PORT=34050
RUSTFS_CONSOLE_PORT=34051
CLICKHOUSE_S3_ENDPOINT=http://rustfs:9000

# BaoStock
BAOSTOCK_HOST=public-api.baostock.com
BAOSTOCK_PORT=10030
BAOSTOCK_USERNAME=anonymous
BAOSTOCK_PASSWORD=123456
BAOSTOCK_CONNECT_TIMEOUT_SECONDS=15
BAOSTOCK_REQUEST_TIMEOUT_SECONDS=20
BAOSTOCK_LOGIN_TIMEOUT_SECONDS=15
BAOSTOCK_MAX_REQUEST_ATTEMPTS=4

# ClickHouse
CLICKHOUSE_DB=mono_fleur
CLICKHOUSE_USER=mono_fleur
CLICKHOUSE_PASSWORD=change-me-clickhouse-password
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_HTTP_PORT=34052
CLICKHOUSE_NATIVE_PORT=34053
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=34052
CLICKHOUSE_DATABASE=raw
CLICKHOUSE_DBT_SCHEMA=analytics
CLICKHOUSE_SECURE=false
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=10
CLICKHOUSE_QUERY_TIMEOUT_SECONDS=300

# PostgreSQL
POSTGRES_DB=pipeline
POSTGRES_USER=mono_fleur
POSTGRES_PASSWORD=change-me-postgres-password
