# RustFS
RUSTFS_ACCESS_KEY=fleur
RUSTFS_SECRET_KEY=change-me-rustfs-secret
RUSTFS_ENDPOINT=http://127.0.0.1:34050
RUSTFS_BUCKET=fleur
RUSTFS_API_PORT=34050
RUSTFS_CONSOLE_PORT=34051
CLICKHOUSE_S3_ENDPOINT=http://rustfs:9000

# BaoStock
BAOSTOCK_HOST=public-api.baostock.com
BAOSTOCK_PORT=10030
BAOSTOCK_USERNAME=anonymous
BAOSTOCK_PASSWORD=123456
BAOSTOCK_CONNECT_TIMEOUT_SECONDS=15
BAOSTOCK_REQUEST_TIMEOUT_SECONDS=20
BAOSTOCK_LOGIN_TIMEOUT_SECONDS=15
BAOSTOCK_MAX_REQUEST_ATTEMPTS=4

# ClickHouse
CLICKHOUSE_DB=fleur
CLICKHOUSE_USER=fleur
CLICKHOUSE_PASSWORD=change-me-clickhouse-password
CLICKHOUSE_DEFAULT_ACCESS_MANAGEMENT=1
CLICKHOUSE_HTTP_PORT=34052
# Docker Compose native protocol exposure for manual ops only. Furnace uses
# FURNACE_CLICKHOUSE_URL below and does not read this port.
CLICKHOUSE_NATIVE_PORT=34053
CLICKHOUSE_HOST=127.0.0.1
CLICKHOUSE_PORT=34052
CLICKHOUSE_DATABASE=raw
CLICKHOUSE_DBT_SCHEMA=analytics
CLICKHOUSE_SECURE=false
CLICKHOUSE_CONNECT_TIMEOUT_SECONDS=10
CLICKHOUSE_QUERY_TIMEOUT_SECONDS=300

# Furnace ClickHouse HTTP client. This is the only Furnace ClickHouse entry
# point; it targets the ClickHouse HTTP port, not the native port or a Docker
# exec wrapper.
FURNACE_BINARY_PATH=engines/target/release/furnace
FURNACE_CLICKHOUSE_URL=http://127.0.0.1:34052
FURNACE_CLICKHOUSE_VALIDATE_SCHEMA=false

# PostgreSQL
POSTGRES_DB=pipeline
POSTGRES_USER=fleur
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_PORT=34054
PIPELINE_DATABASE_URL=postgresql://fleur:change-me-postgres-password@127.0.0.1:34054/pipeline
REARVIEW_DATABASE_URL=postgresql://fleur:change-me-postgres-password@127.0.0.1:34054/rearview

# Rearview
REARVIEW_HTTP_BIND=127.0.0.1:34057
REARVIEW_API_BASE_URL=http://127.0.0.1:34057
REARVIEW_MAX_CONCURRENT_RUNS=1
REARVIEW_CHUNK_SMALL_RANGE_TRADING_DAYS=90
REARVIEW_CLICKHOUSE_MARTS_DATABASE=fleur_marts
REARVIEW_CLICKHOUSE_MAX_EXECUTION_TIME_SECONDS=300
REARVIEW_CLICKHOUSE_MAX_ROWS_TO_READ=1000000000
REARVIEW_CLICKHOUSE_MAX_BYTES_TO_READ=100000000000
REARVIEW_NATS_URL=nats://127.0.0.1:34055
REARVIEW_PORTFOLIO_STREAM=REARVIEW_PORTFOLIO
REARVIEW_PORTFOLIO_REQUEST_SUBJECT=rearview.portfolio_run.requested
REARVIEW_PORTFOLIO_WORKER_DURABLE=rearview-portfolio-worker
REARVIEW_PORTFOLIO_WORKER_QUEUE=rearview-portfolio-workers

# Frontend / Playwright CDP
VITE_REARVIEW_API_BASE_URL=http://127.0.0.1:34057
PLAYWRIGHT_CDP_ENDPOINT=http://127.0.0.1:9222

# NATS
NATS_CLIENT_PORT=34055
NATS_MONITOR_PORT=34056

# Production-like Docker Compose ports (35xxx)
FLEUR_IMAGE_TAG=local
FLEUR_HTTP_PORT=35080
FLEUR_PROD_RUSTFS_API_PORT=35050
FLEUR_PROD_RUSTFS_CONSOLE_PORT=35051
FLEUR_PROD_CLICKHOUSE_HTTP_PORT=35052
FLEUR_PROD_CLICKHOUSE_NATIVE_PORT=35053
FLEUR_PROD_POSTGRES_PORT=35054
FLEUR_PROD_NATS_CLIENT_PORT=35055
FLEUR_PROD_NATS_MONITOR_PORT=35056
FLEUR_PROD_REARVIEW_HTTP_PORT=35057

# Dagster
DAGSTER_HOME=/storage/program/fleur/.dagster
DAGSTER_WEBSERVER_BASE_URL=http://localhost:3000
DAGSTER_CODE_LOCATION_NAME=scheduler

# JIUYAN 不需要可以不填
JIUYAN_COOKIE=SESSION=change-me

# JIUYAN OCR 不需要可以不填
JIUYAN_OCR_BASE_URL=http://127.0.0.1:34005
JIUYAN_OCR_MODEL_NAME=Qwen3.5-4B
JIUYAN_OCR_TIMEOUT_SECONDS=180
JIUYAN_OCR_MAX_RETRIES=2
JIUYAN_OCR_MAX_CONCURRENT_REQUESTS=6
JIUYAN_OCR_STALE_RUNNING_SECONDS=3600

# SLACK 不需要可以不填
SLACK_BOT_TOKEN=xoxb-change-me
SLACK_CHANNEL_ID=C0000000000
SLACK_HTTP_PROXY=
