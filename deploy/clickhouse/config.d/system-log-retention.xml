<clickhouse>
    <!-- Keep development system log tables bounded. These settings affect
         system log table creation on startup; existing tables may need ALTER
         TABLE ... MODIFY TTL once after this file is introduced. -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </query_log>

    <trace_log>
        <database>system</database>
        <table>trace_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 1 DAY DELETE</ttl>
    </trace_log>

    <text_log>
        <database>system</database>
        <table>text_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 1 DAY DELETE</ttl>
    </text_log>

    <metric_log>
        <database>system</database>
        <table>metric_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 1 DAY DELETE</ttl>
    </metric_log>

    <asynchronous_metric_log>
        <database>system</database>
        <table>asynchronous_metric_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 1 DAY DELETE</ttl>
    </asynchronous_metric_log>

    <part_log>
        <database>system</database>
        <table>part_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </part_log>

    <processors_profile_log>
        <database>system</database>
        <table>processors_profile_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </processors_profile_log>

    <query_metric_log>
        <database>system</database>
        <table>query_metric_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </query_metric_log>

    <background_schedule_pool_log>
        <database>system</database>
        <table>background_schedule_pool_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </background_schedule_pool_log>

    <error_log>
        <database>system</database>
        <table>error_log</table>
        <partition_by>event_date</partition_by>
        <ttl>event_date + INTERVAL 3 DAY DELETE</ttl>
    </error_log>
</clickhouse>
